@model CantinaEscolar.Models.Compra

@using System.Globalization

@{
    var br = new CultureInfo("pt-BR");
}

@{
    ViewData["Title"] = "Detalhes da Compra";
}

<div class="container mt-4">
    <h2>Detalhes da Compra</h2>
    <hr />

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Data</dt>
                <dd class="col-sm-9">@Model.Data.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Aluno</dt>
                <dd class="col-sm-9">@Model.Aluno?.Nome</dd>

                <dt class="col-sm-3">Valor Total</dt>
                <dd class="col-sm-9 fw-bold">@Model.ValorTotal.ToString("C", br)</dd>
            </dl>

            @if (Model.Itens != null && Model.Itens.Any())
            {
                <h5 class="mt-4">Itens da Compra</h5>

                <table class="table table-striped table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th>Produto</th>
                            <th class="text-end">Quantidade</th>
                            <th class="text-end">Preço Unitário</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td>@item.Produto?.Nome</td>
                                <td class="text-end">@item.Quantidade</td>
                                <td class="text-end">@item.PrecoUnitario.ToString("C", br)</td>
                                <td class="text-end">@((item.Quantidade * item.PrecoUnitario).ToString("C", br))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">
                    Esta compra não possui itens cadastrados.
                </div>
            }

            <a asp-action="Index" class="btn btn-secondary">
                Voltar
            </a>
        </div>
    </div>
</div>