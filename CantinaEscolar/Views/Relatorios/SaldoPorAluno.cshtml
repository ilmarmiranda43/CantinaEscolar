@model IEnumerable<CantinaEscolar.Controllers.SaldoPorAlunoVM>

@using System.Globalization

@{
    var br = new CultureInfo("pt-BR");
}

@{
    ViewData["Title"] = "Saldo por Aluno";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>Relatório de Saldo por Aluno</h2>
            <p class="text-muted mb-0">
                Consulta dos saldos disponíveis no mês atual.
            </p>
        </div>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-secondary">
            Voltar para início
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <table class="table table-striped table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>Aluno</th>
                        <th>Responsável</th>
                        <th>Série</th>
                        <th class="text-end">Limite</th>
                        <th class="text-end">Consumido no Mês</th>
                        <th class="text-end">Disponível</th>
                        <th class="text-center">Detalhes</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Aluno</td>
                            <td>@item.Responsavel</td>
                            <td>@item.Serie</td>
                            <td class="text-end">@item.Limite.ToString("C", br)</td>
                            <td class="text-end">@item.ConsumidoMes.ToString("C", br)</td>
                            <td class="text-end fw-bold">@item.Disponivel.ToString("C", br)</td>

                            <td class="text-center">
                                <a asp-controller="Relatorios"
                                   asp-action="DetalhesComprasAluno"
                                   asp-route-alunoId="@item.AlunoId"
                                   class="btn btn-sm btn-outline-primary">
                                    Ver compras
                                </a>
                            </td>
                        </tr>
                        
                    }
                </tbody>

                <tfoot class="table-secondary">
                    <tr>
                        <th colspan="4">Totais</th>
                        <th class="text-end">@Model.Sum(a => a.Limite).ToString("C", br)</th>
                        <th class="text-end">@Model.Sum(a => a.ConsumidoMes).ToString("C", br)</th>
                        <th class="text-end">@Model.Sum(a => a.Disponivel).ToString("C", br)</th>
                    </tr>
                </tfoot>
            </table>

        </div>
    </div>
</div>